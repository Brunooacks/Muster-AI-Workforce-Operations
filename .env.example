# ============================================================================
# Cohort — Environment variables
# ============================================================================
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
#
# There are two ways to run Cohort:
#   1. On Replit — auth (Clerk) and the OpenAI integration are provisioned by
#      Replit; you only need DATABASE_URL. The REPLIT_* vars are injected.
#   2. Self-hosted (Render/Railway/Fly/AWS/GCP/etc.) — you must provide every
#      value below yourself. The REPLIT_* vars are then irrelevant.
# ============================================================================


# ----------------------------------------------------------------------------
# Core (always required)
# ----------------------------------------------------------------------------

# Postgres connection string. Locally, a docker Postgres or Neon/Supabase URL.
# Example: postgresql://user:password@host:5432/cohort?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cohort

# Port the API server listens on. Required — the server refuses to boot without it.
PORT=8080

# development | production
NODE_ENV=development

# pino log level: trace|debug|info|warn|error|fatal (default: info)
LOG_LEVEL=info


# ----------------------------------------------------------------------------
# Auth — Clerk  (API server)
# ----------------------------------------------------------------------------
# Self-hosted: create a Clerk project at https://dashboard.clerk.com and paste
# its keys here. On Replit these are managed by the Auth pane — leave blank.

# Backend secret key (sk_test_... / sk_live_...). Used by the Clerk proxy.
CLERK_SECRET_KEY=

# Publishable key fallback used when the host cannot be derived (pk_test_.../pk_live_...).
CLERK_PUBLISHABLE_KEY=


# ----------------------------------------------------------------------------
# Auth — Clerk  (frontend / Vite build)
# ----------------------------------------------------------------------------
# These are baked into the frontend bundle at BUILD time (must be present when
# running `pnpm --filter @workspace/cohort run build`).

# Frontend publishable key (pk_test_... / pk_live_...). Required by the SPA.
VITE_CLERK_PUBLISHABLE_KEY=

# Optional: custom Clerk Frontend-API proxy URL. Leave blank to use the default
# same-origin proxy path (/api/__clerk).
VITE_CLERK_PROXY_URL=


# ----------------------------------------------------------------------------
# OpenAI integration  (agent source analysis — analyze.ts)
# ----------------------------------------------------------------------------
# Self-hosted: point these at the real OpenAI API (or an Azure/OpenAI-compatible
# gateway). On Replit these are injected by the OpenAI integration.

# https://api.openai.com/v1  (or your gateway base URL)
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# sk-...  (your OpenAI API key)
AI_INTEGRATIONS_OPENAI_API_KEY=


# ----------------------------------------------------------------------------
# GitHub — private repo import (optional)
# ----------------------------------------------------------------------------
# Only needed to import agents from PRIVATE GitHub repos. Public repos work
# without it. A fine-grained PAT with `contents: read` is enough.
# GITHUB_TOKEN / GH_TOKEN / GITHUB_ACCESS_TOKEN are all accepted (first wins).
GITHUB_TOKEN=


# ----------------------------------------------------------------------------
# Replit-managed (do NOT set when self-hosting — injected by Replit only)
# ----------------------------------------------------------------------------
# REPLIT_CONNECTORS_HOSTNAME=
# REPL_IDENTITY=
# WEB_REPL_RENEWAL=
# REPL_ID=
# BASE_PATH=
